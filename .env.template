# 🔧 Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# =====================================================
# 🚨 CRITICAL CONFIGURATION - MUST BE SET
# =====================================================

# Database Connection (REQUIRED)
# MongoDB Cloud URL:
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create free cluster and get connection string
# 3. Replace placeholders: <username>, <password>, <cluster-url>
# Example: mongodb+srv://admin:password123@cluster0.xxxxx.mongodb.net/petty_cash_db
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>.mongodb.net/petty_cash_db?retryWrites=true&w=majority

# JWT Secret (REQUIRED - CHANGE IN PRODUCTION!)
# Generate a secure random string:
# - Minimum 32 characters
# - Mix of uppercase, lowercase, numbers, special characters
# - Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_for_production

# Email Configuration (REQUIRED - for user invitations and reports)
# Gmail Setup Instructions:
# 1. Go to Google Account > Security (https://myaccount.google.com/security)
# 2. Enable 2-Step Verification
# 3. Go to App passwords
# 4. Generate password for "Mail" and "Windows Computer"
# 5. Use the 16-digit password below (remove spaces)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=Pettyca$h <noreply@yourcompany.com>

# CEO Email (REQUIRED - for weekly reports)
# Set to the email that should receive Monday 9 AM reports
# Multi-domain variants will be auto-generated (.com and .in)
CEO_EMAIL=ceo@yourcompany.com

# Frontend URL (REQUIRED - for email links and CORS)
# Use the URL where your frontend is deployed
# Examples:
#   FRONTEND_URL=http://localhost:3001 (development)
#   FRONTEND_URL=https://petty-cash.yourdomain.com (production)
FRONTEND_URL=http://localhost:3001

# =====================================================
# 📊 Server Configuration
# =====================================================

PORT=5000
NODE_ENV=development

# =====================================================
# 📧 Email Service Options
# =====================================================

# Option 1: Gmail SMTP (Free - recommended for small deployments)
# Already configured above (EMAIL_HOST, EMAIL_PORT, EMAIL_USER, EMAIL_PASSWORD)

# Option 2: SendGrid (For larger deployments)
# Get API key from: https://sendgrid.com/
# Uncomment and fill if using SendGrid:
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# =====================================================
# 📁 File Upload Configuration
# =====================================================

UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# =====================================================
# 🔐 Token Configuration
# =====================================================

JWT_EXPIRE=7d

# =====================================================
# 🌍 CORS Configuration
# =====================================================

CORS_ORIGIN=http://localhost:3001

# =====================================================
# 📍 Application Features Configuration
# =====================================================

# Time Zone (for scheduler jobs)
TIMEZONE=Asia/Kolkata

# Environment
LOG_LEVEL=debug

# =====================================================
# ⚠️ IMPORTANT NOTES FOR DEPLOYMENT
# =====================================================

# 1. NEVER commit this file to Git repository - add .env to .gitignore
# 2. In production, set env vars through your hosting platform:
#    - Vercel: Set in Environment Variables panel
#    - Heroku: Use heroku config:set command
#    - Docker: Pass via docker run -e or docker-compose.yml
#    - VPS: Set in .env file (keep it private)
# 3. Keep backups of production credentials securely
# 4. Rotate JWT_SECRET periodically
# 5. Use app-specific passwords for Gmail (not your actual password)
# 6. Test email configuration before deploying to production
# 7. Monitor scheduler logs for weekly report execution

